# scripts/seed-secrets.example.env
#
# Copy this file to scripts/seed-secrets.env and fill in the values.
# `scripts/seed-secrets.env` is gitignored — never commit real secrets.
#
# Then run:
#   ENV=prod ./scripts/seed-secrets.sh
#
# The script regroups these flat keys into the 5 JSON-shaped Secrets
# Manager entries that the Helm chart (helm/insur-iq) wires into pods
# via envFrom: secretRef. See:
#   - helm/insur-iq/templates/_helpers.tpl  (backendEnvFrom)
#   - helm/insur-iq/templates/external-secret.yaml
#
# Auto-fetched values are intentionally absent below — the script
# resolves them from `terraform output` so you don't have to look
# them up. Auto-generated values (BETTER_AUTH_SECRET, SECRET_KEY,
# WEBHOOK_SECRET_KEY) are filled in on first run if left blank, then
# written back here so re-runs are idempotent.

# ── insur-iq/<env>/backend ────────────────────────────────────────
SECRET_KEY=                 # auto-generated if blank: openssl rand -hex 32
WEBHOOK_SECRET_KEY=         # auto-generated if blank: openssl rand -hex 32 — seeded into both backend and auth secrets

# ── insur-iq/<env>/db ─────────────────────────────────────────────
# DB_HOST is auto-filled from `terraform output -raw rds_proxy_endpoint`.
# DB_PASSWORD is auto-fetched from the RDS master secret
# (`terraform output -raw rds_master_secret_arn`).
# DATABASE_STRING_AUTH is computed from the resolved fields below.
DB_PORT=5432
DB_USER=insur_iq
DB_NAME=insure_iq
DB_NAME_AUTH=auth

# ── insur-iq/<env>/redis ──────────────────────────────────────────
# CELERY_BROKER_URL is auto-built from `terraform output -raw redis_endpoint`
# as redis://<endpoint>/<REDIS_DB_INDEX>.
REDIS_DB_INDEX=0

# ── insur-iq/<env>/auth ───────────────────────────────────────────
BETTER_AUTH_SECRET=         # auto-generated if blank: openssl rand -hex 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── insur-iq/<env>/llm ────────────────────────────────────────────
LLM_PROVIDER=gemini             # gemini | openai | anthropic — selects which *_API_KEY/_MODEL is used
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
