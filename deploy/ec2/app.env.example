# =============================================================================
# cart-iq EC2 app box — environment file
# =============================================================================
# Copy to app.env and fill in. NEVER commit app.env — it holds secrets and is
# gitignored. Most infra-derived values can be generated with:
#
#   terraform -chdir=infra/terraform-ec2 output -raw app_env_snippet > deploy/ec2/app.env
#
# then fill the __FILL__ placeholders (auth + LLM keys) by hand.
# =============================================================================

# ---- Images ----------------------------------------------------------------
ECR_REGISTRY=123456789012.dkr.ecr.ap-south-1.amazonaws.com
BACKEND_TAG=1.0.0
WEB_TAG=1.0.0
SCRAPER_TAG=1.0.0
AUTH_TAG=latest

# ---- Public host -----------------------------------------------------------
DOMAIN=cartiq.acmecorp.com

# ---- Django core -----------------------------------------------------------
DEBUG=False
APP_ENV=PROD
SECRET_KEY=__FILL__
WEBHOOK_SECRET_KEY=__FILL__
# localhost/127.0.0.1/backend are needed for the container healthcheck and
# intra-stack calls; the nginx proxy forwards the public DOMAIN as Host.
ALLOWED_HOSTS=cartiq.acmecorp.com,localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=https://cartiq.acmecorp.com
HOST_NAME=https://cartiq.acmecorp.com

# ---- Database (direct to RDS — no Proxy) -----------------------------------
# DB_PASSWORD: aws secretsmanager get-secret-value --secret-id <rds_master_secret_arn> \
#   --query SecretString --output text | jq -r .password
DB_HOST=cart-iq-prod-ec2.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=cart_iq
DB_PASSWORD=__FILL_FROM_SECRETS_MANAGER__
DB_NAME=cart_iq
DB_NAME_AUTH=auth
# Parity-chat read connection. v1 reuses the main user (no read-only role);
# blank password inherits DB_PASSWORD in the app.
PARITY_CHAT_DB_USER=cart_iq
PARITY_CHAT_DB_PASSWORD=

# ---- Redis (container on this box, broker only) ----------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_CACHE_BACKEND=django-cache

# ---- S3 --------------------------------------------------------------------
# The EC2 instance profile provides AWS credentials — do NOT set
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (would short-circuit boto3's chain).
AWS_REGION=ap-south-1
AWS_STORAGE_BUCKET_NAME=cart-iq-prod-ec2-uploads
AWS_S3_ENDPOINT_URL=
AWS_S3_PUBLIC_ENDPOINT_URL=
AWS_SENDER_EMAIL=

# ---- Embedding + parity-chat tuning ----------------------------------------
EMBED_MODEL=gemini-embedding-2
EMBED_DIMENSIONS=1536
GEMINI_USE_VERTEX_AI=False
EMBED_USE_VERTEX_AI=
PARITY_CHAT_CACHE_ENABLED=False
ANTHROPIC_RATIONALES_ENABLED=False
PARITY_CHAT_MODEL=anthropic/claude-opus-4-7

# ---- Scraper tunables (keep SCRAPER_MAX_CONCURRENCY in sync with the scraper
#      worker's --concurrency in docker-compose.app.yml) ----------------------
SCRAPER_DEFAULT_PINCODE=110001
SCRAPER_MAX_CONCURRENCY=3
SCRAPER_RATE_LIMIT_ENABLED=True
SCRAPER_LISTING_PARTITION=True

# ---- Auth (Better Auth) ----------------------------------------------------
# DATABASE_STRING for auth is composed in compose from DB_* above + DB_NAME_AUTH.
BETTER_AUTH_SECRET=__FILL__
REQUIRE_EMAIL_VERIFICATION=false
# OAuth providers (optional — leave blank to disable a provider):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Comma-separated providers surfaced in the web UI (e.g. google,github):
NUXT_PUBLIC_ENABLED_SOCIAL_PROVIDERS=

# ---- AI provider + keys ----------------------------------------------------
# AI_PROVIDER: google | openai | anthropic | groq | together | ollama
AI_PROVIDER=google
# GOOGLE_API_KEY is the Gemini key the backend reads. EMBED_GOOGLE_API_KEY blank
# → inherits GOOGLE_API_KEY.
GOOGLE_API_KEY=__FILL__
EMBED_GOOGLE_API_KEY=
# Alternatives (only the selected provider's key is read):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# OLLAMA_API_BASE=
