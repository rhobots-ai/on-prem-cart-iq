# deploy.example.env
#
# Copy this file to deploy.env (in the repo root) and fill in the values
# for your environment. `deploy.env` is gitignored — never commit it.
#
# Then load it into your shell once per terminal session:
#
#   source ./deploy.env
#
# Every command in eks-deployment-guide.md (terraform, aws, kubectl, helm,
# scripts/*.sh) reads these. An empty $AWS_REGION is the usual cause of
# `argument --region: expected one argument` from the AWS CLI.
#
# After Terraform has applied, also export the values it emits — see the
# "Post-Terraform" block at the bottom.

# ---- Set before running Terraform --------------------------------------

export ENV=prod                         # prod | staging | dev
export DEBUG=False                      # True | False — never True in prod
export AWS_REGION=ap-south-1
export CLUSTER_NAME=cart-iq-$ENV
export NAMESPACE=cart-iq
export DOMAIN=cartiq.acmecorp.com      # the FQDN the ALB will serve

# Your 12-digit AWS account ID. Used to construct IAM role ARNs and SNS topic
# ARNs in the runbook (§5 Pod Identity fallback, §appendix alerting). Get it
# with: aws sts get-caller-identity --query Account --output text
export AWS_ACCOUNT_ID=

# OPTIONAL — bring-your-own ACM certificate. If you already have a regional
# (in $AWS_REGION) ISSUED cert that covers $DOMAIN, set its ARN here and
# Terraform will use it as-is instead of creating a new one. Leaving this
# blank tells Terraform to request a new DNS-validated cert (you then
# create the validation CNAME in §4a). Either path produces the same
# `acm_certificate_arn` Terraform output downstream.
export ACM_CERTIFICATE_ARN=

# Route53 hosted zone ID for $DOMAIN. Required in §4a if Terraform is
# requesting the ACM cert AND your hosted zone lives in the same AWS
# account (used by the `aws route53 change-resource-record-sets` call
# that creates the validation CNAME). Leave blank if you set
# ACM_CERTIFICATE_ARN above, or if your DNS lives elsewhere
# (Cloudflare, a separate AWS account, etc.) — in that case you'll
# create the CNAME manually in your provider.
export ROUTE53_ZONE_ID=

# ---- Post-Terraform (uncomment after `terraform apply` succeeds) -------
#
# These come from `terraform -chdir=infra/terraform output`. They are
# required by §4a (DNS validation) and §8 (verify-infra.sh).
#
export ACM_CERT_ARN=$(terraform -chdir=infra/terraform output -raw acm_certificate_arn)
export RDS_PROXY_ENDPOINT=$(terraform -chdir=infra/terraform output -raw rds_proxy_endpoint)
export REDIS_ENDPOINT=$(terraform -chdir=infra/terraform output -raw redis_endpoint)
export S3_BUCKET=$(terraform -chdir=infra/terraform output -raw s3_bucket_name)
